# Application Environment
NODE_ENV=development
PORT=3000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database Configuration
# Format: postgresql://username:password@localhost:5432/database_name
# Example: postgresql://postgres:password@localhost:5432/nexcart_dev
DATABASE_URL=postgresql://user:password@localhost:5432/nexcart_dev

# Redis TCP Configuration (Optional: BullMQ, cache, Socket.IO multi-instance)
# Format: redis://localhost:6379 or rediss://default:password@host:6379
# REDIS_URL=redis://localhost:6379

# Upstash REST Configuration (cache)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# JWT Authentication
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long
JWT_EXPIRATION=7d

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@nexcart.com
RESEND_FROM_NAME=NexCart

# Cloudinary Configuration (Optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payment Gateway Configuration (Optional)
# Options: stripe, paypal, razorpay
PAYMENT_GATEWAY=stripe
PAYMENT_API_KEY=your_payment_key
PAYMENT_API_SECRET=your_payment_secret
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:3000/checkout/success
STRIPE_CANCEL_URL=http://localhost:3000/checkout/cancel

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration (Optional)
SESSION_SECRET=your-session-secret-must-be-at-least-32-characters-long

# Socket.IO Configuration (Optional)
SOCKET_NAMESPACE=/
SOCKET_CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Google OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Better Auth Configuration
BETTER_AUTH_SECRET=your-better-auth-secret-must-be-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000/api/v1/auth
