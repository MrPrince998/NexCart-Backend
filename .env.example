# Application Environment
NODE_ENV=development
PORT=3000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database Configuration
# Format: postgresql://username:password@localhost:5432/database_name
# Example: postgresql://postgres:password@localhost:5432/nexcart_dev
DATABASE_URL=postgresql://user:password@localhost:5432/nexcart_dev

# Redis Configuration (Upstash)
REDIS_URL=https://your-redis-url.upstash.io
REDIS_TOKEN=your_redis_token

# JWT Authentication
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long
JWT_EXPIRATION=7d

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@nexcart.com
RESEND_FROM_NAME=NexCart

# Cloudinary Configuration (Optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payment Gateway Configuration (Optional)
# Options: stripe, paypal, razorpay
PAYMENT_GATEWAY=stripe
PAYMENT_API_KEY=your_payment_key
PAYMENT_API_SECRET=your_payment_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration (Optional)
SESSION_SECRET=your-session-secret-must-be-at-least-32-characters-long

# Socket.IO Configuration (Optional)
SOCKET_NAMESPACE=/
SOCKET_CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Google OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Better Auth Configuration
BETTER_AUTH_SECRET=your-better-auth-secret-must-be-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000/api/v1/auth
